# ── Bot de Telegram ─────────────────────────────────────────────
BOT_TOKEN=TU_BOT_TOKEN_AQUI
BOT_USERNAME=CineStelar_bot

# ── Canal donde TÚ envías TODO el contenido (películas, series, anime) ──
INTAKE_CHANNEL_ID=-100XXXXXXXXXX

# ── Canales de distribución (el bot reenvía automáticamente) ────
MOVIES_CHANNEL_ID=-100XXXXXXXXXX
SERIES_CHANNEL_ID=-100XXXXXXXXXX
ANIME_CHANNEL_ID=-100XXXXXXXXXX

# ── Canal público de verificación (usuarios deben unirse) ───────
VERIFICATION_CHANNEL_ID=-100XXXXXXXXXX
VERIFICATION_CHANNEL_USERNAME=@tu_canal

# ── Notificaciones a grupos (opcional, separados por coma) ──────
NOTIFICATION_GROUPS=

# ── Base de Datos (SQLite por defecto, cambia a PostgreSQL para producción) ──
DATABASE_URL=sqlite+aiosqlite:///bot.db

# ── TMDb API ────────────────────────────────────────────────────
TMDB_API_KEY=TU_TMDB_API_KEY

# ── Admin IDs (separados por coma) ──────────────────────────────
ADMIN_IDS=123456789
